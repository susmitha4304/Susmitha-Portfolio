rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helper for contact messages
    function isValidContactMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'timestamp'])
        && data.keys().size() <= 5
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 150
        && data.message is string && data.message.size() >= 1 && data.message.size() <= 5000
        && data.timestamp is string && data.timestamp.size() <= 40
        && (!data.keys().hasAny(['subject']) || (data.subject is string && data.subject.size() <= 200));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for visitor messages
    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidContactMessage(request.resource.data);
      allow get, list, update, delete: if false; // Visitors cannot read or alter other submissions
    }
  }
}
